# Finance Application — Environment Variables

DEBUG=True

# Django secret key (generate a secure one for production)
SECRET_KEY=your-django-secret-key-minimum-50-characters

# PostgreSQL connection string (same format as before)
DATABASE_URL=postgresql://postgres:password@localhost:5432/finance_db

# JWT settings
JWT_ACCESS_SECRET=your-access-secret-here-minimum-32-characters
JWT_ACCESS_EXPIRES_MINUTES=15
JWT_REFRESH_EXPIRES_DAYS=7

# Allowed hosts (comma-separated, use * for development)
ALLOWED_HOSTS=*

# CORS
CORS_ALLOW_ALL_ORIGINS=True
