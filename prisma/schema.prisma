// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ------------------------------------
// Enums
// ------------------------------------

// Roles define what a user can do in the system.
// VIEWER  → read-only access to records and dashboard
// ANALYST → read + create + update records; access detailed insights
// ADMIN   → full access including user management and deletion

// Note: SQLite does not support native enums; we store these as plain strings
// and enforce validity at the application layer via Zod schemas.

// ------------------------------------
// Models
// ------------------------------------

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  // role: VIEWER | ANALYST | ADMIN
  role         String   @default("VIEWER")
  // status: ACTIVE | INACTIVE
  status       String   @default("ACTIVE")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  records       FinancialRecord[]
  refreshTokens RefreshToken[]
}

model FinancialRecord {
  id       String   @id @default(cuid())
  amount   Float
  // type: INCOME | EXPENSE
  type     String
  category String
  date     DateTime
  notes    String?

  // Soft delete — never hard-delete records from the database.
  // Deleted records are filtered with `WHERE deletedAt IS NULL` in all queries.
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@index([type])
  @@index([category])
  @@index([date])
}

model RefreshToken {
  id        String   @id @default(cuid())
  // Token is stored hashed for security. 
  // We compare the SHA-256 hash of the incoming token against this value.
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  createdAt DateTime @default(now())
}
